---
import Layout from "../components/Layout.astro";
import Button from "../components/Button.astro";
import { site } from "../data/site.js";

const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');
---

<Layout title="Home" description={site.headline} activePage="home">
  <div class="container">
    <section class="hero">
      <h1 class="hero__name">{site.name}</h1>
      <p class="hero__headline">{site.headline}</p>
      <p class="hero__intro">{site.intro}</p>

      <div class="hero__actions">
        <Button href={`${base}cv`} variant="primary">CV</Button>
        <Button href={`${base}projects`} variant="primary">Projects</Button>
        <Button href={site.github} target="_blank">GitHub</Button>
        <Button href={site.linkedin} target="_blank">LinkedIn</Button>
        <Button href={`${base}cv.pdf`} download variant="secondary">Download CV (PDF)</Button>
      </div>
    </section>
  </div>
</Layout>
